# Turso libsql
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Per-source bearer token expected on POST /api/ingest.
# Add one env var per consumer source, named SOURCE_TOKEN_<UPPER_SOURCE>.
SOURCE_TOKEN_ASK_ZEROINDEX=

# Basic-auth password for /admin/*
ADMIN_PASSWORD=

# Shared secret required by /api/rollup (set in Vercel Cron config)
CRON_SECRET=

# Optional: the source the public / and /admin pages render by default.
# Defaults to ask-zeroindex when unset.
DEFAULT_SOURCE=
